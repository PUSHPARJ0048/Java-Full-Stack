class Vehicle{
    String brand = "Ford";
    public void honk() {
        System.out.println("Beep beep!");
    }
}
class Car extends Vehicle {
    String model = "mustang";
    public void displayInfo(){
        System.out.println(brand);
        System.out.println(model);
    }
}
public class Main {
    public static void main(String[] args) {
        Car myCar = new Car();
        myCar.honk();
        myCar.displayInfo();
    }
}
