//Calculator using switch case and while
import java.util.Scanner;
public class Calculator {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        while (true) {
            System.out.print("Enter first number: ");
            double num1 = scanner.nextDouble();
            System.out.print("Enter operator (+, -, *, /): ");
            char operator = scanner.next().charAt(0);
            System.out.print("Enter second number: ");
            double num2 = scanner.nextDouble();
            double result;
            switch (operator) {
                case '+':
                    result = num1 + num2;
                    System.out.println("Result: " + result);
                    break;
                case '-':
                    result = num1 - num2;
                    System.out.println("Result: " + result);
                    break;
                case '*':
                    result = num1 * num2;
                    System.out.println("Result: " + result);
                    break;
                case '/':
                    if (num2 != 0) {
                        result = num1 / num2;
                        System.out.println("Result: " + result);
                    } else {
                        System.out.println("Error: Cannot divide by zero.");
                    }
                    break;
                default:
                    System.out.println("Error: Invalid operator.");
            }
            System.out.print("Do you want to continue? (y/n): ");
            char choice = scanner.next().charAt(0);
            if (choice == 'n' || choice == 'N') {
                break;
            }
        }
        scanner.close();
        System.out.println("Calculator Closed.");
    }
}
// for loop
//Printing number from 1-100 even and odd saperately using for loop
public class EvenOdd {
    public static void main(String[] args) {
        System.out.println("\nEven Numbers (1-100):");
        for (int i = 1; i <= 100; i++) {
            if (i % 2 == 0) {
                System.out.print(i + " ");
            }
        }
        System.out.println("\n\nOdd Numbers (1-100):");
        for (int i = 1; i <= 100; i++) {
            if (i % 2 != 0) {
                System.out.print(i + " ");
            }
        }
    }
}
//Adding data in an Array using for loop
import java.util.Arrays;
class Main {
    public static void main(String[] args) {
        String[] classNames = {"pushpa", "bal", "babblu"};
        String newStr = "venky"; 
        String[] newArray = Arrays.copyOf(classNames, classNames.length + 1);
        newArray[newArray.length - 1] = newStr;
        System.out.println(newArray[3]);
        System.out.print("Array: ");
        for(int i = 0; i < newArray.length; i++) {
            System.out.print(newArray[i] + " ");
        }
    }
}
